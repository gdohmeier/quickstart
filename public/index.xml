    <item>
      <title>Mancala</title>
      <link>http://localhost:1313/post/2026-03-25-mandala/</link>
      <pubDate>Tue, 24 Mar 2026 23:35:00 -0400</pubDate>
      <guid>http://localhost:1313/post/2026-03-25-mandala/</guid>
      <description>&lt;h2 id=&#34;mancala-shortcode&#34;&gt;mancala shortcode&lt;/h2&gt;&#xA;&lt;p&gt;&lt;div class=&#34;app-container&#34;&gt;&#xA;&#xA;    &lt;head&gt;&#xA;        &lt;meta charset=&#34;UTF-8&#34;&gt;&#xA;        &lt;meta name=&#34;viewport&#34; content=&#34;width=device-width, initial-scale=1.0&#34;&gt;&#xA;        &lt;title&gt;Mancala Game&lt;/title&gt;&#xA;        &lt;script src=&#34;https://cdn.tailwindcss.com&#34;&gt;&lt;/script&gt;&#xA;        &lt;script src=&#34;https://kit.fontawesome.com/a076d05399.js&#34; crossorigin=&#34;anonymous&#34;&gt;&lt;/script&gt;&#xA;        &lt;style&gt;&#xA;             &#xA;            .mancala-board {&#xA;                perspective: 1000px;&#xA;            }&#xA;&#xA;            .pit {&#xA;                transition: all 0.3s ease;&#xA;                cursor: pointer;&#xA;                transform-style: preserve-3d;&#xA;            }&#xA;&#xA;            .pit:hover:not(.disabled) {&#xA;                transform: translateY(-5px) scale(1.05);&#xA;                box-shadow: 0 10px 20px rgba(0, 0, 0, 0.2);&#xA;            }&#xA;&#xA;            .stone {&#xA;                animation: drop-in 0.5s ease;&#xA;            }&#xA;&#xA;            @keyframes drop-in {&#xA;                from {&#xA;                    opacity: 0;&#xA;                    transform: translateY(-20px);&#xA;                }&#xA;&#xA;                to {&#xA;                    opacity: 1;&#xA;                    transform: translateY(0);&#xA;                }&#xA;            }&#xA;&#xA;            .disabled {&#xA;                opacity: 0.5;&#xA;                cursor: not-allowed;&#xA;            }&#xA;&#xA;            #rulesModal {&#xA;                transition: all 0.3s ease;&#xA;            }&#xA;        &lt;/style&gt;&#xA;    &lt;/head&gt;&#xA;&#xA;    &lt;body class=&#34;bg-amber-100 min-h-screen flex flex-col items-center justify-center p-4&#34;&gt;&#xA;        &lt;div class=&#34;max-w-4xl w-full&#34;&gt;&#xA;            &lt;header class=&#34;text-center mb-6&#34;&gt;&#xA;                &lt;h1 class=&#34;text-4xl font-bold text-amber-800 mb-2&#34;&gt;Mancala&lt;/h1&gt;&#xA;                &lt;div class=&#34;flex justify-center space-x-4 mb-4&#34;&gt;&#xA;                    &lt;button id=&#34;resetBtn&#34;&#xA;                        class=&#34;px-4 py-2 bg-amber-700 text-white rounded-lg hover:bg-amber-800 transition&#34;&gt;&#xA;                        &lt;i class=&#34;fas fa-redo mr-2&#34;&gt;&lt;/i&gt;Reset Game&#xA;                    &lt;/button&gt;&#xA;                    &lt;button id=&#34;rulesBtn&#34;&#xA;                        class=&#34;px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition&#34;&gt;&#xA;                        &lt;i class=&#34;fas fa-question-circle mr-2&#34;&gt;&lt;/i&gt;How to Play&#xA;                    &lt;/button&gt;&#xA;                &lt;/div&gt;&#xA;                &lt;div class=&#34;flex justify-center items-center space-x-6&#34;&gt;&#xA;                    &lt;div class=&#34;text-center&#34;&gt;&#xA;                        &lt;div id=&#34;playerScore&#34; class=&#34;text-3xl font-bold text-amber-700&#34;&gt;0&lt;/div&gt;&#xA;                        &lt;div class=&#34;text-sm text-gray-600&#34;&gt;Player&lt;/div&gt;&#xA;                    &lt;/div&gt;&#xA;                    &lt;div class=&#34;flex items-center space-x-4&#34;&gt;&#xA;                        &lt;span class=&#34;text-gray-700&#34;&gt;Difficulty:&lt;/span&gt;&#xA;                        &lt;select id=&#34;difficulty&#34; class=&#34;border rounded px-3 py-1 bg-white&#34;&gt;&#xA;                            &lt;option value=&#34;easy&#34;&gt;Easy&lt;/option&gt;&#xA;                            &lt;option value=&#34;medium&#34; selected&gt;Medium&lt;/option&gt;&#xA;                            &lt;option value=&#34;hard&#34;&gt;Hard&lt;/option&gt;&#xA;                        &lt;/select&gt;&#xA;                    &lt;/div&gt;&#xA;                    &lt;div class=&#34;text-center&#34;&gt;&#xA;                        &lt;div id=&#34;computerScore&#34; class=&#34;text-3xl font-bold text-amber-700&#34;&gt;0&lt;/div&gt;&#xA;                        &lt;div class=&#34;text-sm text-gray-600&#34;&gt;Computer&lt;/div&gt;&#xA;                    &lt;/div&gt;&#xA;                &lt;/div&gt;&#xA;            &lt;/header&gt;&#xA;&#xA;            &lt;div class=&#34;mancala-board bg-amber-800 rounded-xl shadow-xl p-6 mb-6 relative overflow-hidden&#34;&gt;&#xA;                &#xA;                &lt;div class=&#34;absolute top-2 right-2 w-14 h-full flex flex-col items-center justify-center&#34;&gt;&#xA;                    &lt;div id=&#34;computerBank&#34;&#xA;                        class=&#34;bg-amber-900 rounded-full w-14 h-40 flex items-center justify-center text-white text-2xl font-bold mb-2&#34;&gt;&#xA;                        0&#xA;                    &lt;/div&gt;&#xA;                    &lt;span class=&#34;text-white text-xs&#34;&gt;Computer Bank&lt;/span&gt;&#xA;                &lt;/div&gt;&#xA;&#xA;                &lt;div class=&#34;flex flex-col items-center gap-2 py-2&#34;&gt;&#xA;                    &#xA;                    &#xA;&#xA;                    &#xA;                    &lt;div class=&#34;flex justify-center mb-4&#34;&gt;&#xA;                        &lt;div class=&#34;flex gap-x-4&#34;&gt;&#xA;                            &#xA;                            &lt;div id=&#34;pitC5&#34;&#xA;                                class=&#34;pit bg-amber-600 rounded-full w-14 h-14 flex items-center justify-center text-white text-lg font-bold cursor-not-allowed disabled&#34;&gt;&#xA;                                4&lt;/div&gt;&#xA;                            &lt;div id=&#34;pitC4&#34;&#xA;                                class=&#34;pit bg-amber-600 rounded-full w-14 h-14 flex items-center justify-center text-white text-lg font-bold cursor-not-allowed disabled&#34;&gt;&#xA;                                4&lt;/div&gt;&#xA;                            &lt;div id=&#34;pitC3&#34;&#xA;                                class=&#34;pit bg-amber-600 rounded-full w-14 h-14 flex items-center justify-center text-white text-lg font-bold cursor-not-allowed disabled&#34;&gt;&#xA;                                4&lt;/div&gt;&#xA;                            &lt;div id=&#34;pitC2&#34;&#xA;                                class=&#34;pit bg-amber-600 rounded-full w-14 h-14 flex items-center justify-center text-white text-lg font-bold cursor-not-allowed disabled&#34;&gt;&#xA;                                4&lt;/div&gt;&#xA;                            &lt;div id=&#34;pitC1&#34;&#xA;                                class=&#34;pit bg-amber-600 rounded-full w-14 h-14 flex items-center justify-center text-white text-lg font-bold cursor-not-allowed disabled&#34;&gt;&#xA;                                4&lt;/div&gt;&#xA;                            &lt;div id=&#34;pitC0&#34;&#xA;                                class=&#34;pit bg-amber-600 rounded-full w-14 h-14 flex items-center justify-center text-white text-lg font-bold cursor-not-allowed disabled&#34;&gt;&#xA;                                4&lt;/div&gt;&#xA;                        &lt;/div&gt;&#xA;                    &lt;/div&gt;&#xA;&#xA;                    &#xA;                    &lt;div class=&#34;flex justify-center mt-4 mb-4&#34;&gt;&#xA;                        &lt;div class=&#34;flex gap-x-4&#34;&gt;&#xA;                            &#xA;                            &lt;div id=&#34;pitP0&#34;&#xA;                                class=&#34;pit bg-amber-600 rounded-full w-14 h-14 flex items-center justify-center text-white text-lg font-bold hover:bg-amber-500&#34;&gt;&#xA;                                4&lt;/div&gt;&#xA;                            &lt;div id=&#34;pitP1&#34;&#xA;                                class=&#34;pit bg-amber-600 rounded-full w-14 h-14 flex items-center justify-center text-white text-lg font-bold hover:bg-amber-500&#34;&gt;&#xA;                                4&lt;/div&gt;&#xA;                            &lt;div id=&#34;pitP2&#34;&#xA;                                class=&#34;pit bg-amber-600 rounded-full w-14 h-14 flex items-center justify-center text-white text-lg font-bold hover:bg-amber-500&#34;&gt;&#xA;                                4&lt;/div&gt;&#xA;                            &lt;div id=&#34;pitP3&#34;&#xA;                                class=&#34;pit bg-amber-600 rounded-full w-14 h-14 flex items-center justify-center text-white text-lg font-bold hover:bg-amber-500&#34;&gt;&#xA;                                4&lt;/div&gt;&#xA;                            &lt;div id=&#34;pitP4&#34;&#xA;                                class=&#34;pit bg-amber-600 rounded-full w-14 h-14 flex items-center justify-center text-white text-lg font-bold hover:bg-amber-500&#34;&gt;&#xA;                                4&lt;/div&gt;&#xA;                            &lt;div id=&#34;pitP5&#34;&#xA;                                class=&#34;pit bg-amber-600 rounded-full w-14 h-14 flex items-center justify-center text-white text-lg font-bold hover:bg-amber-500&#34;&gt;&#xA;                                4&lt;/div&gt;&#xA;                        &lt;/div&gt;&#xA;                    &lt;/div&gt;&#xA;&#xA;                &lt;/div&gt;&#xA;&#xA;&#xA;                &#xA;                &lt;div class=&#34;absolute top-2 left-2 w-14 h-full flex flex-col items-center justify-center&#34;&gt;&#xA;                    &lt;div id=&#34;playerBank&#34;&#xA;                        class=&#34;bg-amber-900 rounded-full w-14 h-40 flex items-center justify-center text-white text-2xl font-bold mb-2&#34;&gt;&#xA;                        0&#xA;                    &lt;/div&gt;&#xA;                    &lt;span class=&#34;text-white text-xs&#34;&gt;Player Bank&lt;/span&gt;&#xA;                &lt;/div&gt;&#xA;&#xA;                &#xA;                &lt;div id=&#34;turnIndicator&#34;&#xA;                    class=&#34;absolute bottom-2 left-1/2 transform -translate-x-1/2 bg-amber-700 text-white px-4 py-1 rounded-full text-sm&#34;&gt;&#xA;                    Your Turn&#xA;                &lt;/div&gt;&#xA;            &lt;/div&gt;&#xA;&#xA;            &#xA;            &lt;div id=&#34;statusMessage&#34; class=&#34;text-center text-lg text-amber-800 font-semibold mb-6 h-8&#34;&gt;&#xA;                Click on your pits to start playing!&#xA;            &lt;/div&gt;&#xA;        &lt;/div&gt;&#xA;&#xA;        &#xA;        &lt;div id=&#34;rulesModal&#34; class=&#34;fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center hidden z-50&#34;&gt;&#xA;            &lt;div class=&#34;bg-white rounded-lg p-6 max-w-lg w-full max-h-[80vh] overflow-y-auto&#34;&gt;&#xA;                &lt;div class=&#34;flex justify-between items-center mb-4&#34;&gt;&#xA;                    &lt;h2 class=&#34;text-2xl font-bold text-amber-800&#34;&gt;How to Play Mancala&lt;/h2&gt;&#xA;                    &lt;button id=&#34;closeRulesBtn&#34; class=&#34;text-gray-500 hover:text-gray-700&#34;&gt;&#xA;                        &lt;i class=&#34;fas fa-times&#34;&gt;&lt;/i&gt;&#xA;                    &lt;/button&gt;&#xA;                &lt;/div&gt;&#xA;                &lt;div class=&#34;space-y-4&#34;&gt;&#xA;                    &lt;div&gt;&#xA;                        &lt;h3 class=&#34;text-xl font-semibold text-amber-700&#34;&gt;Objective&lt;/h3&gt;&#xA;                        &lt;p&gt;Collect as many stones as possible in your bank by the end of the game.&lt;/p&gt;</description>
    </item>
    <item>
      <title>Rocks</title>
      <link>http://localhost:1313/post/2026-03-25-rocks/</link>
      <pubDate>Tue, 24 Mar 2026 23:34:00 -0400</pubDate>
      <guid>http://localhost:1313/post/2026-03-25-rocks/</guid>
      <description>&lt;h2 id=&#34;rocks-shortcode&#34;&gt;rocks shortcode&lt;/h2&gt;&#xA;&lt;div class=&#34;app-container&#34;&#xA;    style=&#34;position: relative; width: 100%; max-width: 680px; margin: 2rem auto; background: #000; border: 2px solid #333; border-radius: 8px; overflow: hidden; box-shadow: 0 4px 20px rgba(0,0,0,0.6);&#34;&gt;&#xA;&#xA;    &lt;div style=&#34;position: relative; width: 640px; height: 480px; margin: 0 auto;&#34;&gt;&#xA;        &lt;canvas id=&#34;rocks-canvas&#34; width=&#34;640&#34; height=&#34;480&#34; style=&#34;display: block;&#34;&gt;&lt;/canvas&gt;&#xA;&#xA;        &lt;div&#xA;            style=&#34;position: absolute; top: 10px; left: 10px; z-index: 20; display: flex; flex-direction: column; gap: 6px;&#34;&gt;&#xA;            &lt;button class=&#34;rocks-btn&#34; data-action=&#34;start&#34;&gt;Start&lt;/button&gt;&#xA;            &lt;button class=&#34;rocks-btn&#34; data-action=&#34;stop&#34;&gt;Stop&lt;/button&gt;&#xA;            &lt;button class=&#34;rocks-btn&#34; data-action=&#34;info&#34;&gt;Info&lt;/button&gt;&#xA;        &lt;/div&gt;&#xA;&#xA;        &lt;div id=&#34;rocks-info&#34;&#xA;            style=&#34;position: absolute; top: 10px; right: 10px; background: rgba(0,0,0,0.85); padding: 10px 14px; border: 1px solid #555; border-radius: 6px; font-family: monospace; font-size: 13px; color: #eee; display: none; pointer-events: none; z-index: 15;&#34;&gt;&#xA;            &lt;table style=&#34;border-collapse: collapse;&#34;&gt;&#xA;                &lt;thead&gt;&#xA;                    &lt;tr&gt;&#xA;                        &lt;th&gt;#&lt;/th&gt;&#xA;                        &lt;th&gt;X&lt;/th&gt;&#xA;                        &lt;th&gt;Y&lt;/th&gt;&#xA;                    &lt;/tr&gt;&#xA;                &lt;/thead&gt;&#xA;                &lt;tbody id=&#34;rocks-pos-tbody&#34;&gt;&lt;/tbody&gt;&#xA;            &lt;/table&gt;&#xA;        &lt;/div&gt;&#xA;    &lt;/div&gt;&#xA;&#xA;    &lt;style&gt;&#xA;        .rocks-btn {&#xA;            width: 78px;&#xA;            padding: 6px 0;&#xA;            font-size: 12px;&#xA;            background: rgba(70, 70, 70, 0.9);&#xA;            color: #eee;&#xA;            border: 1px solid #777;&#xA;            border-radius: 4px;&#xA;            cursor: pointer;&#xA;            transition: all 0.13s;&#xA;        }&#xA;&#xA;        .rocks-btn:hover {&#xA;            background: rgba(100, 100, 100, 0.9);&#xA;            border-color: #aaa;&#xA;        }&#xA;&#xA;        .rocks-btn.active {&#xA;            background: #2a6 !important;&#xA;            border-color: #4a8 !important;&#xA;        }&#xA;    &lt;/style&gt;&#xA;&#xA;    &lt;script&gt;&#xA;        (function () {&#xA;            &#xA;&#xA;            const container = document.currentScript.closest(&#39;.app-container&#39;);&#xA;            if (!container) return;&#xA;&#xA;            const canvas = container.querySelector(&#39;#rocks-canvas&#39;);&#xA;            if (!canvas) return;&#xA;&#xA;            const ctx = canvas.getContext(&#39;2d&#39;);&#xA;            const infoPanel = container.querySelector(&#39;#rocks-info&#39;);&#xA;            const posTbody = container.querySelector(&#39;#rocks-pos-tbody&#39;);&#xA;            const buttons = container.querySelectorAll(&#39;.rocks-btn&#39;);&#xA;&#xA;            const WIDTH = 640;&#xA;            const HEIGHT = 480;&#xA;&#xA;            let shapes = [];&#xA;            let running = false;&#xA;            let showInfo = false;&#xA;            let rafId = null;&#xA;            let observer = null;&#xA;&#xA;            class Shape {&#xA;                constructor() { this.reset(); }&#xA;                reset() {&#xA;                    this.x = 80 + Math.random() * (WIDTH - 160);&#xA;                    this.y = 80 + Math.random() * (HEIGHT - 160);&#xA;                    this.vx = (Math.random() - 0.5) * 4.8;&#xA;                    this.vy = (Math.random() - 0.5) * 4.8;&#xA;                    this.sides = 5 + Math.floor(Math.random() * 4);&#xA;                    this.radius = 26 + Math.random() * 38;&#xA;                    this.points = [];&#xA;                    const step = Math.PI * 2 / this.sides;&#xA;                    for (let i = 0; i &lt; this.sides; i++) {&#xA;                        const a = i * step + (Math.random() - 0.5) * 1.1;&#xA;                        const r = this.radius * (0.6 + Math.random() * 0.75);&#xA;                        this.points.push({ dx: Math.cos(a) * r, dy: Math.sin(a) * r });&#xA;                    }&#xA;                    this.maxR = this.radius * 1.2;&#xA;                }&#xA;                update() {&#xA;                    this.x += this.vx;&#xA;                    this.y += this.vy;&#xA;                    if (this.x - this.maxR &lt; 0 || this.x + this.maxR &gt; WIDTH) { this.vx *= -1; this.x = Math.max(this.maxR, Math.min(WIDTH - this.maxR, this.x)); }&#xA;                    if (this.y - this.maxR &lt; 0 || this.y + this.maxR &gt; HEIGHT) { this.vy *= -1; this.y = Math.max(this.maxR, Math.min(HEIGHT - this.maxR, this.y)); }&#xA;                }&#xA;                draw() {&#xA;                    ctx.save();&#xA;                    ctx.translate(this.x, this.y);&#xA;                    ctx.shadowColor = &#39;white&#39;;&#xA;                    ctx.shadowBlur = 16;&#xA;                    ctx.beginPath();&#xA;                    ctx.moveTo(this.points[0].dx, this.points[0].dy);&#xA;                    this.points.forEach(p =&gt; ctx.lineTo(p.dx, p.dy));&#xA;                    ctx.closePath();&#xA;                    ctx.fillStyle = &#39;white&#39;;&#xA;                    ctx.fill();&#xA;                    ctx.strokeStyle = &#39;#ccc&#39;;&#xA;                    ctx.lineWidth = 1.8;&#xA;                    ctx.stroke();&#xA;                    ctx.restore();&#xA;                }&#xA;            }&#xA;&#xA;            function createShapes() {&#xA;                shapes = Array.from({ length: 7 }, () =&gt; new Shape());&#xA;            }&#xA;&#xA;            function updateTable() {&#xA;                posTbody.innerHTML = &#39;&#39;;&#xA;                shapes.forEach((s, i) =&gt; {&#xA;                    const tr = document.createElement(&#39;tr&#39;);&#xA;                    tr.innerHTML = `&lt;td style=&#34;color:#9f9;&#34;&gt;${i + 1}&lt;/td&gt;&lt;td&gt;${Math.round(s.x)}&lt;/td&gt;&lt;td&gt;${Math.round(s.y)}&lt;/td&gt;`;&#xA;                    posTbody.appendChild(tr);&#xA;                });&#xA;            }&#xA;&#xA;            function animate() {&#xA;                if (!running || !document.body.contains(canvas)) {&#xA;                    rafId = null;&#xA;                    return;&#xA;                }&#xA;&#xA;                ctx.fillStyle = &#39;black&#39;;&#xA;                ctx.fillRect(0, 0, WIDTH, HEIGHT);&#xA;&#xA;                shapes.forEach(s =&gt; {&#xA;                    if (running) s.update();&#xA;                    s.draw();&#xA;                });&#xA;&#xA;                if (showInfo) updateTable();&#xA;&#xA;                rafId = requestAnimationFrame(animate);&#xA;            }&#xA;&#xA;            function startAnimation() {&#xA;                if (running) return;&#xA;                running = true;&#xA;                buttons[0].classList.add(&#39;active&#39;);   &#xA;                buttons[1].classList.remove(&#39;active&#39;); &#xA;                if (!rafId) rafId = requestAnimationFrame(animate);&#xA;            }&#xA;&#xA;            function stopAnimation() {&#xA;                if (!running) return;&#xA;                running = false;&#xA;                buttons[1].classList.add(&#39;active&#39;);&#xA;                buttons[0].classList.remove(&#39;active&#39;);&#xA;                &#xA;                ctx.fillStyle = &#39;black&#39;;&#xA;                ctx.fillRect(0, 0, WIDTH, HEIGHT);&#xA;                shapes.forEach(s =&gt; s.draw());&#xA;                if (showInfo) updateTable();&#xA;            }&#xA;&#xA;            function toggleInfo() {&#xA;                showInfo = !showInfo;&#xA;                infoPanel.style.display = showInfo ? &#39;block&#39; : &#39;none&#39;;&#xA;                buttons[2].classList.toggle(&#39;active&#39;, showInfo);&#xA;                if (showInfo &amp;&amp; running) updateTable();&#xA;            }&#xA;&#xA;            &#xA;            buttons.forEach(btn =&gt; {&#xA;                btn.addEventListener(&#39;click&#39;, () =&gt; {&#xA;                    const action = btn.dataset.action;&#xA;                    if (action === &#39;start&#39;) startAnimation();&#xA;                    if (action === &#39;stop&#39;) stopAnimation();&#xA;                    if (action === &#39;info&#39;) toggleInfo();&#xA;                });&#xA;            });&#xA;&#xA;            &#xA;            observer = new IntersectionObserver(entries =&gt; {&#xA;                if (entries[0].isIntersecting) {&#xA;                    if (running &amp;&amp; !rafId) rafId = requestAnimationFrame(animate);&#xA;                } else {&#xA;                    if (rafId) {&#xA;                        cancelAnimationFrame(rafId);&#xA;                        rafId = null;&#xA;                    }&#xA;                }&#xA;            }, { threshold: 0.1 });&#xA;&#xA;            observer.observe(canvas);&#xA;&#xA;            &#xA;            const cleanup = () =&gt; {&#xA;                if (rafId) cancelAnimationFrame(rafId);&#xA;                if (observer) observer.disconnect();&#xA;            };&#xA;&#xA;            &#xA;            const mo = new MutationObserver(() =&gt; {&#xA;                if (!document.body.contains(container)) cleanup();&#xA;            });&#xA;            mo.observe(document.body, { childList: true, subtree: true });&#xA;&#xA;            &#xA;            createShapes();&#xA;            &#xA;            running = false;&#xA;&#xA;            &#xA;            &#xA;&#xA;        })();&#xA;    &lt;/script&gt;&#xA;&lt;/div&gt;&#xA;&lt;p&gt;Vvvvvvv&lt;/p&gt;</description>
    </item>
