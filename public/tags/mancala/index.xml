    <item>
      <title>Mancala</title>
      <link>http://localhost:1313/post/2026-03-25-mandala/</link>
      <pubDate>Tue, 24 Mar 2026 23:35:00 -0400</pubDate>
      <guid>http://localhost:1313/post/2026-03-25-mandala/</guid>
      <description>&lt;h2 id=&#34;mancala-shortcode&#34;&gt;mancala shortcode&lt;/h2&gt;&#xA;&lt;div class=&#34;app-container&#34;&gt;&#xA;&#xA;    &lt;head&gt;&#xA;        &lt;meta charset=&#34;UTF-8&#34;&gt;&#xA;        &lt;meta name=&#34;viewport&#34; content=&#34;width=device-width, initial-scale=1.0&#34;&gt;&#xA;        &lt;title&gt;Mancala Game&lt;/title&gt;&#xA;        &lt;script src=&#34;https://cdn.tailwindcss.com&#34;&gt;&lt;/script&gt;&#xA;        &lt;script src=&#34;https://kit.fontawesome.com/a076d05399.js&#34; crossorigin=&#34;anonymous&#34;&gt;&lt;/script&gt;&#xA;        &lt;style&gt;&#xA;             &#xA;            .mancala-board {&#xA;                perspective: 1000px;&#xA;            }&#xA;&#xA;            .pit {&#xA;                transition: all 0.3s ease;&#xA;                cursor: pointer;&#xA;                transform-style: preserve-3d;&#xA;            }&#xA;&#xA;            .pit:hover:not(.disabled) {&#xA;                transform: translateY(-5px) scale(1.05);&#xA;                box-shadow: 0 10px 20px rgba(0, 0, 0, 0.2);&#xA;            }&#xA;&#xA;            .stone {&#xA;                animation: drop-in 0.5s ease;&#xA;            }&#xA;&#xA;            @keyframes drop-in {&#xA;                from {&#xA;                    opacity: 0;&#xA;                    transform: translateY(-20px);&#xA;                }&#xA;&#xA;                to {&#xA;                    opacity: 1;&#xA;                    transform: translateY(0);&#xA;                }&#xA;            }&#xA;&#xA;            .disabled {&#xA;                opacity: 0.5;&#xA;                cursor: not-allowed;&#xA;            }&#xA;&#xA;            #rulesModal {&#xA;                transition: all 0.3s ease;&#xA;            }&#xA;        &lt;/style&gt;&#xA;    &lt;/head&gt;&#xA;&#xA;    &lt;body class=&#34;bg-amber-100 min-h-screen flex flex-col items-center justify-center p-4&#34;&gt;&#xA;        &lt;div class=&#34;max-w-4xl w-full&#34;&gt;&#xA;            &lt;header class=&#34;text-center mb-6&#34;&gt;&#xA;                &lt;h1 class=&#34;text-4xl font-bold text-amber-800 mb-2&#34;&gt;Mancala&lt;/h1&gt;&#xA;                &lt;div class=&#34;flex justify-center space-x-4 mb-4&#34;&gt;&#xA;                    &lt;button id=&#34;resetBtn&#34;&#xA;                        class=&#34;px-4 py-2 bg-amber-700 text-white rounded-lg hover:bg-amber-800 transition&#34;&gt;&#xA;                        &lt;i class=&#34;fas fa-redo mr-2&#34;&gt;&lt;/i&gt;Reset Game&#xA;                    &lt;/button&gt;&#xA;                    &lt;button id=&#34;rulesBtn&#34;&#xA;                        class=&#34;px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition&#34;&gt;&#xA;                        &lt;i class=&#34;fas fa-question-circle mr-2&#34;&gt;&lt;/i&gt;How to Play&#xA;                    &lt;/button&gt;&#xA;                &lt;/div&gt;&#xA;                &lt;div class=&#34;flex justify-center items-center space-x-6&#34;&gt;&#xA;                    &lt;div class=&#34;text-center&#34;&gt;&#xA;                        &lt;div id=&#34;playerScore&#34; class=&#34;text-3xl font-bold text-amber-700&#34;&gt;0&lt;/div&gt;&#xA;                        &lt;div class=&#34;text-sm text-gray-600&#34;&gt;Player&lt;/div&gt;&#xA;                    &lt;/div&gt;&#xA;                    &lt;div class=&#34;flex items-center space-x-4&#34;&gt;&#xA;                        &lt;span class=&#34;text-gray-700&#34;&gt;Difficulty:&lt;/span&gt;&#xA;                        &lt;select id=&#34;difficulty&#34; class=&#34;border rounded px-3 py-1 bg-white&#34;&gt;&#xA;                            &lt;option value=&#34;easy&#34;&gt;Easy&lt;/option&gt;&#xA;                            &lt;option value=&#34;medium&#34; selected&gt;Medium&lt;/option&gt;&#xA;                            &lt;option value=&#34;hard&#34;&gt;Hard&lt;/option&gt;&#xA;                        &lt;/select&gt;&#xA;                    &lt;/div&gt;&#xA;                    &lt;div class=&#34;text-center&#34;&gt;&#xA;                        &lt;div id=&#34;computerScore&#34; class=&#34;text-3xl font-bold text-amber-700&#34;&gt;0&lt;/div&gt;&#xA;                        &lt;div class=&#34;text-sm text-gray-600&#34;&gt;Computer&lt;/div&gt;&#xA;                    &lt;/div&gt;&#xA;                &lt;/div&gt;&#xA;            &lt;/header&gt;&#xA;&#xA;            &lt;div class=&#34;mancala-board bg-amber-800 rounded-xl shadow-xl p-6 mb-6 relative overflow-hidden&#34;&gt;&#xA;                &#xA;                &lt;div class=&#34;absolute top-2 right-2 w-14 h-full flex flex-col items-center justify-center&#34;&gt;&#xA;                    &lt;div id=&#34;computerBank&#34;&#xA;                        class=&#34;bg-amber-900 rounded-full w-14 h-40 flex items-center justify-center text-white text-2xl font-bold mb-2&#34;&gt;&#xA;                        0&#xA;                    &lt;/div&gt;&#xA;                    &lt;span class=&#34;text-white text-xs&#34;&gt;Computer Bank&lt;/span&gt;&#xA;                &lt;/div&gt;&#xA;&#xA;                &lt;div class=&#34;flex flex-col items-center gap-2 py-2&#34;&gt;&#xA;                    &#xA;                    &#xA;&#xA;                    &#xA;                    &lt;div class=&#34;flex justify-center mb-4&#34;&gt;&#xA;                        &lt;div class=&#34;flex gap-x-4&#34;&gt;&#xA;                            &#xA;                            &lt;div id=&#34;pitC5&#34;&#xA;                                class=&#34;pit bg-amber-600 rounded-full w-14 h-14 flex items-center justify-center text-white text-lg font-bold cursor-not-allowed disabled&#34;&gt;&#xA;                                4&lt;/div&gt;&#xA;                            &lt;div id=&#34;pitC4&#34;&#xA;                                class=&#34;pit bg-amber-600 rounded-full w-14 h-14 flex items-center justify-center text-white text-lg font-bold cursor-not-allowed disabled&#34;&gt;&#xA;                                4&lt;/div&gt;&#xA;                            &lt;div id=&#34;pitC3&#34;&#xA;                                class=&#34;pit bg-amber-600 rounded-full w-14 h-14 flex items-center justify-center text-white text-lg font-bold cursor-not-allowed disabled&#34;&gt;&#xA;                                4&lt;/div&gt;&#xA;                            &lt;div id=&#34;pitC2&#34;&#xA;                                class=&#34;pit bg-amber-600 rounded-full w-14 h-14 flex items-center justify-center text-white text-lg font-bold cursor-not-allowed disabled&#34;&gt;&#xA;                                4&lt;/div&gt;&#xA;                            &lt;div id=&#34;pitC1&#34;&#xA;                                class=&#34;pit bg-amber-600 rounded-full w-14 h-14 flex items-center justify-center text-white text-lg font-bold cursor-not-allowed disabled&#34;&gt;&#xA;                                4&lt;/div&gt;&#xA;                            &lt;div id=&#34;pitC0&#34;&#xA;                                class=&#34;pit bg-amber-600 rounded-full w-14 h-14 flex items-center justify-center text-white text-lg font-bold cursor-not-allowed disabled&#34;&gt;&#xA;                                4&lt;/div&gt;&#xA;                        &lt;/div&gt;&#xA;                    &lt;/div&gt;&#xA;&#xA;                    &#xA;                    &lt;div class=&#34;flex justify-center mt-4 mb-4&#34;&gt;&#xA;                        &lt;div class=&#34;flex gap-x-4&#34;&gt;&#xA;                            &#xA;                            &lt;div id=&#34;pitP0&#34;&#xA;                                class=&#34;pit bg-amber-600 rounded-full w-14 h-14 flex items-center justify-center text-white text-lg font-bold hover:bg-amber-500&#34;&gt;&#xA;                                4&lt;/div&gt;&#xA;                            &lt;div id=&#34;pitP1&#34;&#xA;                                class=&#34;pit bg-amber-600 rounded-full w-14 h-14 flex items-center justify-center text-white text-lg font-bold hover:bg-amber-500&#34;&gt;&#xA;                                4&lt;/div&gt;&#xA;                            &lt;div id=&#34;pitP2&#34;&#xA;                                class=&#34;pit bg-amber-600 rounded-full w-14 h-14 flex items-center justify-center text-white text-lg font-bold hover:bg-amber-500&#34;&gt;&#xA;                                4&lt;/div&gt;&#xA;                            &lt;div id=&#34;pitP3&#34;&#xA;                                class=&#34;pit bg-amber-600 rounded-full w-14 h-14 flex items-center justify-center text-white text-lg font-bold hover:bg-amber-500&#34;&gt;&#xA;                                4&lt;/div&gt;&#xA;                            &lt;div id=&#34;pitP4&#34;&#xA;                                class=&#34;pit bg-amber-600 rounded-full w-14 h-14 flex items-center justify-center text-white text-lg font-bold hover:bg-amber-500&#34;&gt;&#xA;                                4&lt;/div&gt;&#xA;                            &lt;div id=&#34;pitP5&#34;&#xA;                                class=&#34;pit bg-amber-600 rounded-full w-14 h-14 flex items-center justify-center text-white text-lg font-bold hover:bg-amber-500&#34;&gt;&#xA;                                4&lt;/div&gt;&#xA;                        &lt;/div&gt;&#xA;                    &lt;/div&gt;&#xA;&#xA;                &lt;/div&gt;&#xA;&#xA;&#xA;                &#xA;                &lt;div class=&#34;absolute top-2 left-2 w-14 h-full flex flex-col items-center justify-center&#34;&gt;&#xA;                    &lt;div id=&#34;playerBank&#34;&#xA;                        class=&#34;bg-amber-900 rounded-full w-14 h-40 flex items-center justify-center text-white text-2xl font-bold mb-2&#34;&gt;&#xA;                        0&#xA;                    &lt;/div&gt;&#xA;                    &lt;span class=&#34;text-white text-xs&#34;&gt;Player Bank&lt;/span&gt;&#xA;                &lt;/div&gt;&#xA;&#xA;                &#xA;                &lt;div id=&#34;turnIndicator&#34;&#xA;                    class=&#34;absolute bottom-2 left-1/2 transform -translate-x-1/2 bg-amber-700 text-white px-4 py-1 rounded-full text-sm&#34;&gt;&#xA;                    Your Turn&#xA;                &lt;/div&gt;&#xA;            &lt;/div&gt;&#xA;&#xA;            &#xA;            &lt;div id=&#34;statusMessage&#34; class=&#34;text-center text-lg text-amber-800 font-semibold mb-6 h-8&#34;&gt;&#xA;                Click on your pits to start playing!&#xA;            &lt;/div&gt;&#xA;        &lt;/div&gt;&#xA;&#xA;        &#xA;        &lt;div id=&#34;rulesModal&#34; class=&#34;fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center hidden z-50&#34;&gt;&#xA;            &lt;div class=&#34;bg-white rounded-lg p-6 max-w-lg w-full max-h-[80vh] overflow-y-auto&#34;&gt;&#xA;                &lt;div class=&#34;flex justify-between items-center mb-4&#34;&gt;&#xA;                    &lt;h2 class=&#34;text-2xl font-bold text-amber-800&#34;&gt;How to Play Mancala&lt;/h2&gt;&#xA;                    &lt;button id=&#34;closeRulesBtn&#34; class=&#34;text-gray-500 hover:text-gray-700&#34;&gt;&#xA;                        &lt;i class=&#34;fas fa-times&#34;&gt;&lt;/i&gt;&#xA;                    &lt;/button&gt;&#xA;                &lt;/div&gt;&#xA;                &lt;div class=&#34;space-y-4&#34;&gt;&#xA;                    &lt;div&gt;&#xA;                        &lt;h3 class=&#34;text-xl font-semibold text-amber-700&#34;&gt;Objective&lt;/h3&gt;&#xA;                        &lt;p&gt;Collect as many stones as possible in your bank by the end of the game.&lt;/p&gt;</description>
